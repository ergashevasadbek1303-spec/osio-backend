# ============================================
# OSIO RESTORAN - Environment Variables
# ============================================
# Bu faylni .env ga nusxalang va qiymatlarni o'zgartiring
# cp .env.example .env

# ---------- Database (Neon PostgreSQL) ----------
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ---------- JWT Security ----------
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------- App Settings ----------
APP_ENV=development
APP_NAME=Osio Restaurant
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5500

# ---------- First Superadmin ----------
FIRST_SUPERADMIN_USERNAME=admin
FIRST_SUPERADMIN_EMAIL=admin@osio.uz
FIRST_SUPERADMIN_PASSWORD=change-this-password-immediately
